modules = ["nodejs-20", "web", "bash"]

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
integrations = ["javascript_anthropic_ai_integrations:2.0.0", "javascript_openai_ai_integrations:2.0.0", "javascript_gemini_ai_integrations:2.0.0", "javascript_log_in_with_replit:2.0.0", "javascript_database:1.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = 'Project'

[[workflows.workflow]]
name = 'Project'
mode = 'parallel'
author = 'agent'

[[workflows.workflow.tasks]]
task = 'workflow.run'
args = 'Start application'

[[workflows.workflow]]
name = 'Start application'
author = 'agent'

[[workflows.workflow.tasks]]
task = 'shell.exec'
args = 'npm run dev'
waitForPort = 5000

[workflows.workflow.metadata]
outputType = 'webview'

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5050
externalPort = 3002

[[ports]]
localPort = 24678
externalPort = 3000

[deployment]
deploymentTarget = 'autoscale'
run = ['node', 'dist-server/index.js']
build = ['npm', 'run', 'build']

[postMerge]
path = 'scripts/post-merge.sh'
timeoutMs = 120000
